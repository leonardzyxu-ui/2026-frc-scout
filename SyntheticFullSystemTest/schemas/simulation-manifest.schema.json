{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerhouse.local/scouting/synthetic-full-system-test/simulation-manifest.schema.json",
  "title": "Synthetic Full System Test Manifest",
  "type": "object",
  "required": ["schemaVersion", "simulation", "fixture", "phases", "bridges", "gates", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "simulation": {
      "type": "object",
      "required": ["name", "mode", "seed"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["synthetic-smoke", "cached-real-event", "live-refresh"] },
        "seed": { "type": "integer" },
        "description": { "type": "string" }
      }
    },
    "fixture": {
      "type": "object",
      "required": ["eventKey", "season", "excludedTeamKeys", "pretendOwnTeamPolicy"],
      "additionalProperties": true,
      "properties": {
        "eventKey": { "type": "string", "minLength": 1 },
        "season": { "type": "integer", "minimum": 1992 },
        "excludedTeamKeys": { "type": "array", "items": { "type": "string" } },
        "pretendOwnTeamPolicy": {
          "type": "object",
          "required": ["strategy", "seed"],
          "additionalProperties": true,
          "properties": {
            "strategy": { "enum": ["fixed-team", "seeded-random-participant"] },
            "teamKey": { "type": "string" },
            "seed": { "type": "integer" }
          }
        },
        "matches": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dataSources": { "type": "object", "additionalProperties": true },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "startsAt"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "startsAt": { "type": "string", "minLength": 1 }
        }
      }
    },
    "agentPlan": { "type": "object", "additionalProperties": true },
    "bridges": {
      "type": "object",
      "required": ["modelCore", "webApp", "powerScout"],
      "additionalProperties": true,
      "properties": {
        "modelCore": { "type": "object", "additionalProperties": true },
        "webApp": { "type": "object", "additionalProperties": true },
        "firebase": { "type": "object", "additionalProperties": true },
        "powerScout": { "type": "object", "additionalProperties": true }
      }
    },
    "gates": { "type": "object", "additionalProperties": true },
    "artifacts": { "type": "object", "additionalProperties": true }
  }
}

