{
  "$schema": "../schemas/simulation-manifest.schema.json",
  "schemaVersion": 1,
  "simulation": {
    "name": "full-local-event",
    "mode": "synthetic-full-event",
    "seed": 82491,
    "description": "Full-length local replay with qualification matches, playoffs, six scout rows per match, predictions, audits, and reports."
  },
  "fixture": {
    "eventKey": "2026fullsynthetic",
    "season": 2026,
    "teamCount": 24,
    "qualificationMatches": 72,
    "playoffMatches": 13,
    "excludedTeamKeys": ["frc6706"],
    "pretendOwnTeamPolicy": {
      "strategy": "seeded-random-participant",
      "seed": 82491
    }
  },
  "dataSources": {
    "tba": { "mode": "disabled-local-replay", "required": false },
    "statbotics": { "mode": "synthetic-priors", "required": false },
    "firebase": { "mode": "disabled-local-replay", "required": false }
  },
  "phases": [
    { "id": "pre_scout", "startsAt": "T_MINUS_7_DAYS" },
    { "id": "pit_scout", "startsAt": "PIT_SCOUT_WINDOW" },
    { "id": "practice", "startsAt": "PRACTICE_START" },
    { "id": "qualification_replay", "startsAt": "MATCH_1_POSTED" },
    { "id": "playoff_replay", "startsAt": "PLAYOFF_MATCH_1_POSTED" },
    { "id": "alliance_selection", "startsAt": "ALLIANCE_SELECTION_PREP" }
  ],
  "agentPlan": {
    "defaultPolicy": "deterministic-code-first",
    "spawnAgentsByDefault": false,
    "requiredReportsWhenAgentsUsed": ["codex_swarm.md", "codex_agent_reports/<agent>.md"]
  },
  "bridges": {
    "modelCore": {
      "mode": "local-ledger-runner",
      "commands": ["npm run sft:full-replay", "npm run model:typecheck"]
    },
    "webApp": {
      "mode": "build-and-artifact-ready",
      "routes": ["/adminv2", "/adminv2/prediction-vs-actual", "/adminv4"]
    },
    "firebase": {
      "mode": "disabled-local-replay",
      "productionWrites": false
    },
    "powerScout": {
      "mode": "swiftpm",
      "commands": ["cd PowerScout && swift test", "cd PowerScout && ./script/build_and_run.sh --verify"]
    }
  },
  "gates": {
    "noFutureLeakage": "required",
    "minMatches": 80,
    "minScoutRowsPerMatch": 6,
    "maxUncoveredMatches": 0,
    "maxWinnerAccuracyRegression": 0.03,
    "maxBrierRegression": 0.025,
    "requiredArtifacts": [
      "run-summary.json",
      "replay-event.json",
      "scout-observations.json",
      "prediction-ledger.json",
      "model-metrics.json",
      "no-future-leakage-audit.json",
      "scout-coverage-audit.json",
      "alliance-selection-replay.json",
      "app-bridge-summary.json",
      "morning-report.html"
    ]
  },
  "artifacts": {
    "root": "SyntheticFullSystemTest/artifacts",
    "keepGeneratedOutOfGit": true
  }
}

