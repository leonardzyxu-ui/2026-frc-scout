rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasAdminClaim() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.scoutAdmin == true
      );
    }

    function hasAdminRoleDoc() {
      return signedIn() &&
        exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/adminRoles/$(request.auth.uid)).data.enabled == true;
    }

    function isAdmin() {
      return hasAdminClaim() || hasAdminRoleDoc();
    }

    function isScoutWritePayload() {
      return request.resource.data.keys().hasAll(['teamNumber']) &&
        request.resource.data.teamNumber is string &&
        request.resource.data.teamNumber.size() > 0 &&
        (!('eventKey' in request.resource.data) || request.resource.data.eventKey is string);
    }

    function canWriteScoutRecord(collectionName) {
      return signedIn() &&
        collectionName in [
          'matchScouting',
          'matchScoutingV3',
          'matchScoutingV4',
          'matchScoutingDefense',
          'pitScouting'
        ] &&
        isScoutWritePayload();
    }

    match /adminRoles/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, create, update, delete: if isAdmin();
    }

    match /appState/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId}/{collectionName}/{docId} {
      allow read: if isAdmin();
      allow create, update: if canWriteScoutRecord(collectionName) || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId}/pitAssignments/{teamNumber} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
