{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "lib": [
      "ES2022"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "modeling/src/**/*.ts",
    "modeling/shims.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-local",
    "modeling/artifacts"
  ]
}
