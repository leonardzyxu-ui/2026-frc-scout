# Firebase configuration. Values are public Firebase app identifiers, but keep
# real environment files out of source control and rotate anything previously committed.
VITE_FIREBASE_API_KEY="replace-me"
VITE_FIREBASE_AUTH_DOMAIN="replace-me.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="replace-me"
VITE_FIREBASE_STORAGE_BUCKET="replace-me.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="replace-me"
VITE_FIREBASE_APP_ID="replace-me"

# The Blue Alliance API key used for live schedule/ranking lookups.
VITE_TBA_API_KEY="replace-me"

# Set to true for single-file/local scout builds.
VITE_LOCAL_MODE="false"

# Offline modeling pipeline credentials. These are consumed only by scripts under
# modeling/ and are never bundled into the website.
MODEL_TBA_API_KEY="replace-me"
FIRST_EVENTS_USERNAME="replace-me"
FIRST_EVENTS_AUTH_TOKEN="replace-me"
MODEL_FIREBASE_PROJECT_ID="replace-me"
MODEL_FIREBASE_ACCESS_TOKEN="replace-me"
